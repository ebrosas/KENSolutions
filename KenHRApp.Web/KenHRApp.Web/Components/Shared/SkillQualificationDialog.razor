@using KenHRApp.Web.Components.Common

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@DialogIcon" Class="mr-1" Size="Size.Medium" Color="@DialogIconColor" />
            @DialogTitle
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form">
            <MudPaper Elevation="0" Square="true" Class="w-100 px-5">
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.QualificationDesc"
                                              SearchFunc="SearchQualification!"
                                              Variant="Variant.Text"
                                              Label="Qualification"
                                              Margin="Margin.Dense"
                                              Dense="true"
                                              Placeholder="Please Select"
                                              HelperText="Type a key to search for qualification"
                                              HelperTextOnFocus="true"
                                              Clearable="@IsClearable" Typo="Typo.subtitle2"
                                              MaxItems="@(QualificationList != null ? QualificationList.Count : 10)"
                                              Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.StreamDesc"
                                             SearchFunc="SearchStream!"
                                             Variant="Variant.Text"
                                             Label="Stream"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for stream"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(StreamList != null ? StreamList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.SpecializationDesc"
                                             SearchFunc="SearchSpecialization!"
                                             Variant="Variant.Text"
                                             Label="Specialization"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for specialization"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(SpecializationList != null ? SpecializationList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.QualificationModeDesc"
                                             SearchFunc="SearchQualificationMode!"
                                             Variant="Variant.Text"
                                             Label="Qualification Mode"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for qualification mode"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(QualificationModeList != null ? QualificationModeList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudTextField @bind-Value="Qualification.UniversityName"
                                          For="@(() => Qualification.UniversityName)"
                                          HelperText="Max. text input is 200 chars." Variant="Variant.Text" HelperTextOnFocus="true"
                                          Counter="200" MaxLength="200" Disabled="false" Label="University Name"
                                          Clearable="false" Immediate="@IsDisabled" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudTextField @bind-Value="Qualification.Institute"
                                          For="@(() => Qualification.Institute)"
                                          HelperText="Max. text input is 100 chars." Variant="Variant.Text" HelperTextOnFocus="true"
                                          Counter="100" MaxLength="100" Disabled="false" Label="Institute"
                                          Clearable="false" Immediate="@IsDisabled" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.CountryDesc"
                                             SearchFunc="SearchCountry!"
                                             Variant="Variant.Text"
                                             Label="Country"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for country"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(CountryList != null ? CountryList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudTextField @bind-Value="Qualification.StateCode"
                                          For="@(() => Qualification.StateCode)"
                                          HelperText="Max. text input is 20 chars." Variant="Variant.Text" HelperTextOnFocus="true"
                                          Counter="20" MaxLength="20" Disabled="false" Label="State"
                                          Clearable="false" Immediate="@IsDisabled" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudTextField @bind-Value="Qualification.CityTownName"
                                          For="@(() => Qualification.CityTownName)"
                                          HelperText="Max. text input is 100 chars." Variant="Variant.Text" HelperTextOnFocus="true"
                                          Counter="100" MaxLength="100" Disabled="false" Label="State"
                                          Clearable="false" Immediate="@IsDisabled" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                        
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.FromMonthDesc"
                                             SearchFunc="SearchMonth!"
                                             Variant="Variant.Text"
                                             Label="From Month"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for month"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(MonthList != null ? MonthList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-50">
                            <MudNumericField @bind-Value="Qualification.FromYear" Label="From Year"
                                             For="@(() => Qualification.FromYear)"
                                             Variant="Variant.Outlined"
                                             HelperText="Maximum input is 9999" HelperTextOnFocus="true" MaxLength="4" Min="0" Max="9999"
                                             Immediate="true" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.ToMonthDesc"
                                             SearchFunc="SearchMonth!"
                                             Variant="Variant.Text"
                                             Label="To Month"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for month"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(MonthList != null ? MonthList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-50">
                            <MudNumericField @bind-Value="Qualification.ToYear" Label="To Year"
                                             For="@(() => Qualification.ToYear)"
                                             Variant="Variant.Outlined"
                                             HelperText="Maximum input is 9999" HelperTextOnFocus="true" MaxLength="4" Min="0" Max="9999"
                                             Immediate="true" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
                <MudGrid Spacing="7">
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-100">
                            <MudAutocomplete @bind-Value="Qualification.PassMonthDesc"
                                             SearchFunc="SearchMonth!"
                                             Variant="Variant.Text"
                                             Label="Pass Month"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             Placeholder="Please Select"
                                             HelperText="Type a key to search for month"
                                             HelperTextOnFocus="true"
                                             Clearable="@IsClearable" Typo="Typo.subtitle2"
                                             MaxItems="@(MonthList != null ? MonthList.Count : 10)"
                                             Modal="true" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Elevation="0" Class="p-0 w-50">
                            <MudNumericField @bind-Value="Qualification.PassYear" Label="Pass Year"
                                             For="@(() => Qualification.PassYear)"
                                             Variant="Variant.Outlined"
                                             HelperText="Maximum input is 9999" HelperTextOnFocus="true" MaxLength="4" Min="0" Max="9999"
                                             Immediate="true" Margin="Margin.Dense" Typo="Typo.subtitle2" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Info" Style="background-color:#004165;" Variant="Variant.Filled" Size="Size.Medium" OnClick="Save">Save</MudButton>
        <MudButton Color="Color.Default" Variant="Variant.Text" Size="Size.Medium" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    #region Fields
    private MudForm _form = new();
    private string[]? _qualificationArray = null;
    private string[]? _streamArray = null;
    private string[]? _specializationArray = null;
    private string[]? _qualificationModeArray = null;
    private string[]? _stateArray = null;
    private string[]? _countryArray = null;
    private string[]? _monthArray = null;        
    #endregion

    #region Parameters and Injections
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public QualificationDTO Qualification { get; set; } = new();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> QualificationList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> StreamList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> SpecializationList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> QualificationModeList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> CountryList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public IReadOnlyList<UserDefinedCodeDTO> MonthList { get; set; } = new List<UserDefinedCodeDTO>();

    [Parameter]
    public bool IsClearable { get; set; } = true;

    [Parameter]
    public bool IsDisabled { get; set; } = true;

    [Parameter]
    public bool IsEditMode { get; set; }

    // Optional UI helpers
    protected string DialogTitle => IsEditMode ? "Edit Qualification" : "Add New Qualification";
    protected string DialogIcon => IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add;
    protected Color DialogIconColor => IsEditMode ? Color.Info : Color.Success;
    #endregion

    #region Page Methods
    protected override void OnInitialized()
    {
        if (QualificationList != null)
            _qualificationArray = QualificationList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();

        if (StreamList != null)
            _streamArray = StreamList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();

        if (SpecializationList != null)
            _specializationArray = SpecializationList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();

        if (QualificationModeList != null)
            _qualificationModeArray = QualificationModeList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();                    

        if (CountryList != null)
            _countryArray = CountryList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();

        if (MonthList != null)
            _monthArray = MonthList.Select(d => d.UDCDesc1).OrderBy(d => d).ToArray();
    }
    #endregion

    #region Private Methods
    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        MudDialog.Close(DialogResult.Ok(Qualification));
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task<IEnumerable<string>> SearchQualification(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _qualificationArray!;
        }

        return _qualificationArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<string>> SearchStream(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _streamArray!;
        }

        return _streamArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<string>> SearchSpecialization(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _specializationArray!;
        }

        return _specializationArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<string>> SearchQualificationMode(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _qualificationModeArray!;
        }

        return _qualificationModeArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }        

    private async Task<IEnumerable<string>> SearchCountry(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _countryArray!;
        }

        return _countryArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<string>> SearchMonth(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
        {
            return _monthArray!;
        }

        return _monthArray!.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }
    #endregion
}
